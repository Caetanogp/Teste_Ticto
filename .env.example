# --- YayForms ---
# Public embed/share URL of the YayForms form (used by the inline iframe embed).
# Example: https://your-subdomain.yayforms.app/your-form-id
NEXT_PUBLIC_YAYFORMS_EMBED_URL=

# Optional: form ID used by the official YayForms script embed (data-yf-widget).
NEXT_PUBLIC_YAYFORMS_EMBED_ID=

# --- Site ---
# Canonical production URL (used for metadata / Open Graph). Set after deploy.
NEXT_PUBLIC_SITE_URL=
